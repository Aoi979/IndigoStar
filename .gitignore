core/kernel.png
src/**/kernel.png

# Temporary excalidraw files
draw/temp.excalidraw

# NVIDIA Nsight Compute new reports (existing tracked reports remain)
*.ncu-rep

# New benchmark CSVs (existing tracked files remain)
bench_csv/*.csv
