# C / C++ / CUDA compiled objects
# ============================================
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dll
*.dylib
*.exe
*.out
*.app

# CUDA intermediate files
*.ptx
*.fatbin
*.cubin

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/

# ============================================
# IDE / Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
*.tmp

# AI / Agent tooling
.agents/
.codex/

# ============================================
# clangd / LSP cache
# ============================================
.cache/
.cache/clangd/

