# ============================================
# Build directories
# ============================================
# CMake out-of-source builds
build/
build_*/
build.*/
out/
cmake-build-*/

# ============================================
# CMake generated files (in-source build guard)
# ============================================
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Testing/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps/
build.ninja
.ninja_deps
.ninja_log

